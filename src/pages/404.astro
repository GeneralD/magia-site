---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Magia">
  <main class="relative grid min-h-screen place-items-center overflow-hidden px-5">
    <div class="pointer-events-none absolute inset-0 grid-bg" aria-hidden="true"></div>
    <div
      class="aurora pointer-events-none absolute left-1/2 top-1/3 h-72 w-72 -translate-x-1/2 rounded-full bg-brand"
      aria-hidden="true"
    >
    </div>
    <div class="relative text-center">
      <p class="font-display text-7xl font-extrabold text-gradient text-glow sm:text-8xl">404</p>
      <h1 class="mt-6 text-2xl font-bold">この呪文は唱えられませんでした</h1>
      <p class="mt-3 text-muted">お探しのページは見つかりませんでした。</p>
      <a
        href="/"
        class="mt-8 inline-block cursor-pointer rounded-xl bg-run px-6 py-3 text-sm font-semibold text-night transition hover:brightness-110 run-glow"
        >ホームに戻る</a
      >
    </div>
  </main>
</Layout>
