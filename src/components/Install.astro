---
const repo = "https://github.com/GeneralD/Magia";
const wiki = "https://github.com/GeneralD/Magia/wiki";

const methods = [
  { label: "Homebrew", tag: "推奨", lines: ["brew tap generald/private", "brew install magia"] },
  { label: "Makefile", tag: null, lines: ["make install"] },
  { label: "Mint", tag: null, lines: ["mint install GeneralD/Magia"] },
];
---

<section id="install" class="relative py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <div class="max-w-2xl">
      <span class="font-mono text-sm text-run">// install</span>
      <h2 class="mt-3 text-3xl font-bold sm:text-4xl">数行で、はじめる</h2>
      <p class="mt-4 text-muted">お好みのパッケージマネージャーから導入できます。</p>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {
        methods.map((m) => (
          <div class="card p-5">
            <div class="flex items-center justify-between">
              <span class="font-display text-sm font-bold tracking-wide">{m.label}</span>
              {m.tag && (
                <span class="rounded-full border border-run/40 bg-run/10 px-2 py-0.5 text-[11px] font-semibold text-run">
                  {m.tag}
                </span>
              )}
            </div>
            <pre class="mt-4 overflow-x-auto rounded-lg border border-line bg-deep p-4 font-mono text-[13px] leading-relaxed text-ink"><code>{m.lines.map((l) => (
              <span class="block"><span class="text-faint select-none">$ </span>{l}</span>
            ))}</code></pre>
          </div>
        ))
      }
    </div>

    <div class="mt-12 overflow-hidden rounded-2xl border border-line bg-gradient-to-br from-surface to-deep p-8 text-center sm:p-12 brand-glow">
      <h3 class="text-2xl font-bold sm:text-3xl">
        次のコレクションを、<span class="text-gradient">Magia</span> で。
      </h3>
      <p class="mx-auto mt-4 max-w-xl text-muted">
        詳しい使い方は Wiki にまとまっています。自己の責任で、ご自由にご利用ください。
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="cursor-pointer rounded-xl bg-run px-6 py-3 text-sm font-semibold text-night transition hover:brightness-110 run-glow"
          >GitHub で始める</a
        >
        <a
          href={wiki}
          target="_blank"
          rel="noopener noreferrer"
          class="cursor-pointer rounded-xl border border-line-strong bg-surface/50 px-6 py-3 text-sm font-semibold text-ink transition-colors hover:border-cyan hover:text-cyan"
          >ドキュメント（Wiki）</a
        >
      </div>
    </div>
  </div>
</section>
