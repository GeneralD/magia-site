---
const repo = "https://github.com/GeneralD/Magia";
---

<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4">
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 rounded-2xl border border-line bg-night/70 px-4 py-3 backdrop-blur-xl sm:px-5"
  >
    <a href="#top" class="group flex items-center gap-2.5" aria-label="Magia ホーム">
      <span
        class="grid h-8 w-8 place-items-center rounded-lg border border-line-strong bg-surface font-display text-lg font-extrabold text-gradient"
        >M</span
      >
      <span class="font-display text-lg font-bold tracking-wide">MAGIA</span>
    </a>

    <div class="hidden items-center gap-7 text-sm text-muted md:flex">
      <a class="transition-colors hover:text-ink" href="#features">機能</a>
      <a class="transition-colors hover:text-ink" href="#how">仕組み</a>
      <a class="transition-colors hover:text-ink" href="#showcase">実績</a>
      <a class="transition-colors hover:text-ink" href="#install">インストール</a>
    </div>

    <div class="flex items-center gap-2">
      <a
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub リポジトリ"
        class="grid h-9 w-9 cursor-pointer place-items-center rounded-lg border border-line text-muted transition-colors hover:border-line-strong hover:text-ink"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.42 7.86 10.95.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.35-1.3-1.71-1.3-1.71-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.25 5.68.42.36.79 1.08.79 2.18v3.23c0 .31.21.67.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.74 18.27.5 12 .5Z"
          ></path>
        </svg>
      </a>
      <a
        href="#install"
        class="cursor-pointer rounded-lg bg-run px-3.5 py-2 text-sm font-semibold text-night transition-transform hover:brightness-110 run-glow"
        >インストール</a
      >
    </div>
  </nav>
</header>
